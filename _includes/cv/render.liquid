<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          {% if page.cv_pdf contains '://' %}
            href="{{ page.cv_pdf }}"
          {% else %}
            href="{{ page.cv_pdf | relative_url }}"
          {% endif %}
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
        >
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    {% if page.cv_pdf %}
      {% if page.cv_pdf contains '://' %}
        {% assign cv_pdf_url = page.cv_pdf %}
      {% else %}
        {% assign cv_pdf_url = page.cv_pdf | relative_url %}
      {% endif %}
      <div class="card mt-3 p-3 cv-pdf-preview">
        <iframe
          src="{{ cv_pdf_url }}#view=FitH"
          title="Jeel Chatrola — CV PDF"
          width="100%"
          height="900"
          loading="lazy"
          style="border: 1px solid var(--global-divider-color); border-radius: 6px;"
        ></iframe>
        <p class="mt-2 mb-0 text-sm">
          <a href="{{ cv_pdf_url }}" target="_blank" rel="noopener noreferrer">
            <i class="fa-solid fa-file-pdf"></i> Open or download PDF
          </a>
        </p>
      </div>
    {% else %}
      <p>No CV PDF configured. Set <code>cv_pdf</code> in the CV page front matter.</p>
    {% endif %}
  </article>
</div>
